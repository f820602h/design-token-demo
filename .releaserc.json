{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["package.json", "CHANGELOG.md"],
        "message": "chore(release): ${nextRelease.version} [skip ci]"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          { "path": "build/css/variables.css",    "label": "CSS Variables"           },
          { "path": "build/scss/_variables.scss",  "label": "SCSS Variables"          },
          { "path": "build/js/tokens.js",          "label": "JavaScript Tokens"       },
          { "path": "build/js/tokens.d.ts",        "label": "TypeScript Declarations" },
          { "path": "build/json/tokens.json",      "label": "JSON Tokens"             }
        ]
      }
    ]
  ]
}
