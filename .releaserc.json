{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/npm",
      {
        "npmPublish": true
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["package.json", "CHANGELOG.md"],
        "message": "chore(release): ${nextRelease.version} [skip ci]"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          { "path": "build/css/light.css",    "label": "CSS Variables (Light)"  },
          { "path": "build/css/dark.css",     "label": "CSS Variables (Dark)"   },
          { "path": "build/scss/_light.scss", "label": "SCSS Variables (Light)" },
          { "path": "build/scss/_dark.scss",  "label": "SCSS Variables (Dark)"  },
          { "path": "build/js/light.js",      "label": "JavaScript Tokens (Light)" },
          { "path": "build/js/dark.js",       "label": "JavaScript Tokens (Dark)"  }
        ]
      }
    ]
  ]
}
